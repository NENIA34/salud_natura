"""Analisis de contenedores WordPress con problemas de memoria (OOM Killer).

Identifica que dominios estan generando eventos OOM y recomienda
ajustes de limites de memoria en Coolify.

Configuracion requerida en .env:
- VPS_HOST: IP o hostname del servidor
- VPS_USER: Usuario SSH (ej: root)
- VPS_PASSWORD: Contrasena SSH
"""
import json
import os
import re
import sys
from collections import defaultdict

import paramiko
from dotenv import load_dotenv


def get_vps_credentials():
    """Obtiene credenciales SSH desde variables de entorno."""
    load_dotenv()
    host = os.getenv('VPS_HOST')
    username = os.getenv('VPS_USER', 'root')
    password = os.getenv('VPS_PASSWORD')
    if not host or not password:
        print("Error: Variables VPS no configuradas")
        sys.exit(1)
    return host, username, password


def extract_hosts_from_labels(labels_json):
    """Extrae dominios de los labels de Traefik."""
    hosts = []
    try:
        labels = json.loads(labels_json)
        for key, value in labels.items():
            if 'traefik.http.routers' in key and 'rule' in key:
                if 'Host(' in value:
                    start = value.find('Host(`') + 6
                    end = value.find('`', start)
                    if end > start:
                        host = value[start:end]
                        if host and host not in hosts:
                            hosts.append(host)
    except:
        pass
    return hosts


def main():
    host, username, password = get_vps_credentials()
    
    client = paramiko.SSHClient()
    client.set_missing_host_key_policy(paramiko.AutoAddPolicy())
    client.connect(hostname=host, username=username, password=password, timeout=15)
    
    print("=" * 80)
    print("ANALISIS DE OOM KILLER Y LIMITES DE MEMORIA")
    print("=" * 80)
    
    # 1. Obtener logs de OOM Killer con detalle de cgroup
    print("\n[1] Analizando logs de OOM Killer...")
    cmd = (
        "journalctl -k --since '7 days ago' --output=short-iso 2>/dev/null | "
        "grep -E 'oom-killer|Killed process|Memory cgroup' | tail -30"
    )
    stdin, stdout, stderr = client.exec_command(cmd)
    oom_logs = stdout.read().decode().strip()
    
    # Extraer menciones de cgroups/contenedores
    container_mentions = defaultdict(int)
    if oom_logs:
        for line in oom_logs.split('\n'):
            match = re.search(r'docker-([a-f0-9]+)', line)
            if match:
                container_id = match.group(1)[:12]
                container_mentions[container_id] += 1
    
    # 2. Obtener todos los contenedores WordPress con info completa
    print("\n[2] Obteniendo informacion de contenedores WordPress...")
    
    cmd = "docker ps --filter 'name=wordpress-' --format '{{json .}}'"
    stdin, stdout, stderr = client.exec_command(cmd)
    containers_json = stdout.read().decode().strip().split('\n')
    
    containers_info = {}
    for line in containers_json:
        if not line.strip():
            continue
        try:
            container = json.loads(line)
            name = container.get('Names', '')
            cid = container.get('ID', '')[:12]
            
            containers_info[name] = {
                'id': cid,
                'image': container.get('Image', ''),
                'status': container.get('Status', ''),
                'ports': container.get('Ports', ''),
                'memory_limit': 'Desconocido',
                'memory_usage': 'N/A',
                'domains': [],
                'oom_events': container_mentions.get(cid, 0)
            }
        except:
            continue
    
    # 3. Para cada contenedor, obtener dominios y limites de memoria
    print("\n[3] Obteniendo dominios y limites de memoria...")
    
    for container_name in containers_info:
        # Obtener dominios
        cmd = f"docker inspect {container_name} --format='{{{{json .Config.Labels}}}}'"
        stdin, stdout, stderr = client.exec_command(cmd)
        labels = stdout.read().decode().strip()
        domains = extract_hosts_from_labels(labels)
        containers_info[container_name]['domains'] = domains if domains else ['No identificado']
        
        # Obtener limite de memoria
        cmd = f"docker inspect {container_name} --format='{{{{.HostConfig.Memory}}}}'"
        stdin, stdout, stderr = client.exec_command(cmd)
        memory_limit = stdout.read().decode().strip()
        
        if memory_limit and memory_limit != '0' and memory_limit != '<no value>':
            try:
                memory_mb = int(memory_limit) / (1024 * 1024)
                containers_info[container_name]['memory_limit'] = f"{memory_mb:.0f}MB"
            except:
                containers_info[container_name]['memory_limit'] = "Sin limite"
        else:
            containers_info[container_name]['memory_limit'] = "Sin limite"
    
    # 4. Mostrar resultados
    print("\n" + "=" * 80)
    print("RESULTADOS DEL ANALISIS")
    print("=" * 80)
    
    # Contar OOM total
    total_oom_events = sum(c['oom_events'] for c in containers_info.values())
    print(f"\n📊 Total de eventos OOM detectados (ultimos 7 dias): {total_oom_events}")
    
    # Ordenar por eventos OOM
    sorted_containers = sorted(containers_info.items(), 
                               key=lambda x: x[1]['oom_events'], 
                               reverse=True)
    
    print("\n📦 CONTENEDORES WORDPRESS Y SUS CONFIGURACIONES:\n")
    
    containers_with_issues = []
    
    for name, info in sorted_containers:
        domains = ', '.join(info['domains'])
        mem_limit = info['memory_limit']
        oom_count = info['oom_events']
        
        # Determinar estado
        status_icon = "✅"
        warning = ""
        
        if oom_count > 0:
            status_icon = "🚨"
            warning = f" [OOM: {oom_count} eventos]"
            containers_with_issues.append((name, domains, mem_limit, oom_count))
        elif mem_limit == "Sin limite":
            status_icon = "⚠️ "
            warning = " [Sin limite de memoria]"
            containers_with_issues.append((name, domains, mem_limit, 0))
        elif mem_limit != "Desconocido":
            try:
                limit_val = int(mem_limit.replace('MB', ''))
                if limit_val < 512:
                    status_icon = "🔴"
                    warning = f" [Limite bajo: {mem_limit}]"
                    containers_with_issues.append((name, domains, mem_limit, 0))
            except:
                pass
        
        print(f"{status_icon} {name}")
        print(f"   Dominios: {domains}")
        print(f"   Limite RAM: {mem_limit}{warning}")
        print()
    
    # 5. Resumen de problemas
    print("=" * 80)
    print("CONTENEDORES QUE REQUIEREN ATENCION")
    print("=" * 80)
    
    if containers_with_issues:
        oom_containers = [c for c in containers_with_issues if c[3] > 0]
        no_limit_containers = [c for c in containers_with_issues if c[2] == "Sin limite" and c[3] == 0]
        low_limit_containers = [c for c in containers_with_issues 
                               if c[2] != "Sin limite" and c[2] != "Desconocido" and c[3] == 0]
        
        if oom_containers:
            print(f"\n🔴 {len(oom_containers)} CONTENEDORES CON EVENTOS OOM (PRIORIDAD ALTA):")
            for name, domains, mem_limit, count in sorted(oom_containers, key=lambda x: x[3], reverse=True):
                print(f"\n   🚨 {name}")
                print(f"      Dominio: {domains}")
                print(f"      Eventos OOM: {count}")
                print(f"      Limite actual: {mem_limit}")
                print(f"      → Recomendacion: Aumentar a 1GB o mas")
        
        if no_limit_containers:
            print(f"\n⚠️  {len(no_limit_containers)} CONTENEDORES SIN LIMITE DE MEMORIA:")
            for name, domains, mem_limit, count in no_limit_containers:
                print(f"   • {name} ({domains})")
            print(f"   → Recomendacion: Configurar limite de 512MB-1GB en Coolify")
        
        if low_limit_containers:
            print(f"\n🟡 {len(low_limit_containers)} CONTENEDORES CON LIMITE BAJO (<512MB):")
            for name, domains, mem_limit, count in low_limit_containers:
                print(f"   • {name}: {mem_limit} ({domains})")
    else:
        print("\n✅ Todos los contenedores tienen configuracion adecuada.")
    
    client.close()
    print("\n" + "=" * 80)


if __name__ == "__main__":
    main()
